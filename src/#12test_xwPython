import wx

class SimpleFrame(wx.Frame):
    def __init__(self, *args, **kwargs):
        super(SimpleFrame, self).__init__(*args, **kwargs)

        # Configuración de la ventana principal
        self.SetTitle("Ejemplo wxPython")
        self.SetSize((400, 200))

        # Creación del panel
        panel = wx.Panel(self)
       #panel.SetBackgroundColour("#2E7D32")  # Fondo verde oscuro para el panel

        # Layout vertical para organizar los widgets
        vbox = wx.BoxSizer(wx.VERTICAL)

        # Etiqueta para mostrar el mensaje
        #font = wx.Font(14, wx.FONTFAMILY_DEFAULT, wx.FONTSTYLE_NORMAL, wx.FONTWEIGHT_BOLD)
        self.label = wx.StaticText(panel, label="Escribe algo y presiona el botón", style=wx.ALIGN_CENTER)
        #self.label.SetForegroundColour("#A5D6A7")  # Texto verde claro
        #self.label.SetFont(font)
        vbox.Add(self.label, flag=wx.ALL | wx.EXPAND, border=10)

        # Cuadro de texto para ingresar datos
        self.text_input = wx.TextCtrl(panel)
        #self.text_input = wx.TextCtrl(panel, style=wx.TE_CENTER)
        #self.text_input.SetBackgroundColour("#388E3C")  # Fondo verde del cuadro
        #self.text_input.SetForegroundColour("#E8F5E9")  # Texto verde claro
        #self.text_input.SetFont(wx.Font(12, wx.FONTFAMILY_DEFAULT, wx.FONTSTYLE_NORMAL, wx.FONTWEIGHT_NORMAL))
        vbox.Add(self.text_input, flag=wx.ALL | wx.EXPAND, border=10)

        # Botón para mostrar el texto ingresado
        button = wx.Button(panel, label="Mostrar texto")
        button.SetBackgroundColour("#66BB6A")  # Botón verde claro
        button.SetForegroundColour("#1B5E20")  # Texto verde oscuro
        button.SetFont(wx.Font(12, wx.FONTFAMILY_DEFAULT, wx.FONTSTYLE_NORMAL, wx.FONTWEIGHT_BOLD))
        button.Bind(wx.EVT_BUTTON, self.on_button_press)
        vbox.Add(button, flag=wx.ALL | wx.CENTER, border=10)

        # Establecemos el layout del panel
        panel.SetSizer(vbox)

    # Método que se ejecuta cuando se presiona el botón
    def on_button_press(self, event):
        entered_text = self.text_input.GetValue()
        if entered_text.strip():
            self.label.SetLabel(f"Has escrito: {entered_text}")
        else:
            self.label.SetLabel("Por favor, escribe algo.")
        self.text_input.Clear()  # Limpiamos el cuadro de texto después de mostrar el mensaje

# Clase principal para ejecutar la aplicación wxPython
class SimpleApp(wx.App):
    def OnInit(self):
        frame = SimpleFrame(None)
        frame.Show()
        return True

# Ejecutamos la aplicación
if __name__ == '__main__':
    app = SimpleApp()
    app.MainLoop()