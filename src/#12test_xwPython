import wx

class SimpleFrame(wx.Frame):
    def __init__(self, *args, **kwargs):
        super(SimpleFrame, self).__init__(*args, **kwargs)

        # Configuración de la ventana principal
        self.SetTitle("Ejemplo wxPython")
        self.SetSize((400, 200))

        # Creación del panel
        panel = wx.Panel(self)

        # Layout vertical para organizar los widgets
        vbox = wx.BoxSizer(wx.VERTICAL)

        # Etiqueta para mostrar el mensaje
        self.label = wx.StaticText(panel, label="Escribe algo y presiona el botón", style=wx.ALIGN_CENTER)
        vbox.Add(self.label, flag=wx.ALL | wx.EXPAND, border=10)

        # Cuadro de texto para ingresar datos
        self.text_input = wx.TextCtrl(panel)
        vbox.Add(self.text_input, flag=wx.ALL | wx.EXPAND, border=10)

        # Botón para mostrar el texto ingresado
        button = wx.Button(panel, label="Mostrar texto")
        button.Bind(wx.EVT_BUTTON, self.on_button_press)  # Evento que llama a on_button_press cuando el botón es presionado
        vbox.Add(button, flag=wx.ALL | wx.CENTER, border=10)

        # Establecemos el layout al panel
        panel.SetSizer(vbox)

    # Método que se ejecuta cuando se presiona el botón
    def on_button_press(self, event):
        entered_text = self.text_input.GetValue()  # Obtiene el texto ingresado en el cuadro de texto
        if entered_text.strip():
            self.label.SetLabel(f"Has escrito: {entered_text}")  # Actualiza la etiqueta con el texto ingresado
        else:
            self.label.SetLabel("Por favor, escribe algo.")  # Mensaje si no se ha ingresado texto

# Clase principal para ejecutar la aplicación wxPython
class SimpleApp(wx.App):
    def OnInit(self):
        frame = SimpleFrame(None)
        frame.Show()
        return True

# Ejecutamos la aplicación
if __name__ == '__main__':
    app = SimpleApp()
    app.MainLoop()